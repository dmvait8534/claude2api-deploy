# ── Server ───────────────────────────────────────────────────────────────────
# PORT=8080

# ── Mode ─────────────────────────────────────────────────────────────────────
# Simple mode: set CLAUDE_SESSION_KEYS to skip PostgreSQL entirely.
# Separate multiple keys with commas.
# CLAUDE_SESSION_KEYS=sk-ant-sid01-xxx,sk-ant-sid01-yyy

# ── PostgreSQL (not needed in simple mode) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=claude2api
DB_PASS=your_db_password
DB_NAME=claude2api

# ── Residential Proxy (leave empty to connect directly) ───────────────────────
PROXY_HOST=
PROXY_PORT=3010
PROXY_USER=
PROXY_PASS=
PROXY_REGION=US

# ── Admin Dashboard ───────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change_me_please

# ── Redis (optional — leave empty for in-memory metrics only) ─────────────────
# REDIS_URL=redis://:your_redis_password@localhost:6379/0

# ── Rate Limiting ─────────────────────────────────────────────────────────────
CLAUDE_DAILY_LIMIT=0    # 0 = unlimited
MAX_RETRIES=3
COOLDOWN_MINUTES=5

# ── API Key Protection (optional) ─────────────────────────────────────────────
# Leave empty to allow all requests without authentication.
# CLAUDE_API_KEY=sk-your-api-key
